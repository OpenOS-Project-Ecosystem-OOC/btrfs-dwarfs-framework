{
	"name": "btrfs-dwarfs-framework",
	"build": {
		"context": ".",
		"dockerfile": "Dockerfile"
	},
	// postCreateCommand runs once after the container is created.
	// Installs bfg (btr-fs-git with bdfs patch) and bdfs-pin-helper.
	"postCreateCommand": "pip3 install --quiet git-filter-repo && make -C /workspaces/workspaces install-bfg install-pin-helper 2>/dev/null || true",
	"remoteEnv": {
		// GITLAB_TOKEN is injected from the host environment or Gitpod secret.
		// Used by bdfs-pin-helper, retroactive scan scripts, and CI tooling.
		"GITLAB_TOKEN": "${localEnv:GITLAB_TOKEN}"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-vscode.cpptools",
				"golang.go"
			]
		}
	}
}
